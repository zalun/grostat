# Growatt API token (required)
GROSTAT_TOKEN=your-api-token-here

# Device serial number
GROSTAT_DEVICE_SN=NFB8922074

# SQLite database path
GROSTAT_DB_PATH=~/.local/share/grostat/grostat.db

# Alert thresholds (phase voltage in V)
GROSTAT_ALERT_WARNING_V=250.0
GROSTAT_ALERT_CRITICAL_V=253.0

# API base URL
GROSTAT_API_BASE=https://openapi.growatt.com/v4/new-api
